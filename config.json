{
  "canvas": {
    "base_url": "https://oc.sjtu.edu.cn"
  },
  "sync": {
    "calendar_name": "SJTU Canvas",
    "lookahead_days": 60
  },
  "course_filter": {
    "mode": "exclude",
    "list": [
      "TA Group",
      "TA Training",
      "Undergraduate Students"
    ]
  },
  "oh_keywords": [
    "Office Hour", "office hour", "office hours",
    "答疑", "OH:", "OH：", "Office Hours:"
  ],
  "rc_keywords": [
    "习题课", "Recitation", "recitation",
    "RC:", "RC：", "习题"
  ],
  "time_patterns": [
    "星期(一|二|三|四|五|六|日|天)\\s*\\d{1,2}:\\d{2}",
    "周(一|二|三|四|五|六|日|天)\\s*\\d{1,2}:\\d{2}",
    "(Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday)\\s*\\d{1,2}:\\d{2}",
    "(Mon|Tue|Wed|Thu|Fri|Sat|Sun)\\s*\\d{1,2}:\\d{2}",
    "\\d{4}-\\d{2}-\\d{2}\\s*\\d{1,2}:\\d{2}",
    "\\d{1,2}:\\d{2}\\s*-\\s*\\d{1,2}:\\d{2}"
  ]
}
