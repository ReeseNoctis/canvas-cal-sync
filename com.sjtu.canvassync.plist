<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.sjtu.canvassync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>cd PROJECT_DIR &amp;&amp; /usr/bin/python3 -u sync.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>PROJECT_DIR</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
    </dict>

    <key>StartInterval</key>
    <integer>172800</integer>

    <key>StandardOutPath</key>
    <string>PROJECT_DIR/data/sync.log</string>

    <key>StandardErrorPath</key>
    <string>PROJECT_DIR/data/sync_error.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
